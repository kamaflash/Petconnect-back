# Database
DATASOURCE_URL=jdbc:postgresql://localhost:5432/petconnect
DATASOURCE_USERNAME=petconnect
DATASOURCE_PASSWORD=change_me

# JWT
JWT_ACCESS_SECRET=base64_encoded_256bit_secret_here
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_SECRET=base64_encoded_256bit_secret_here
JWT_REFRESH_EXPIRATION=2592000000

# Server
SERVER_PORT=8080

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary (set enabled=true to use)
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret